# EHR AI Bridge Toolkit - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===========================
# Database Configuration
# ===========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ehr_bridge
DB_USER=ehr_bridge_user
DB_PASSWORD=your_secure_password_here

# ===========================
# Encryption
# ===========================
# Path to external SSD for encrypted storage
ENCRYPTED_STORAGE_PATH=/Volumes/EHR-Secure/
# Encryption key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_encryption_key_here

# ===========================
# AI Engine Configuration
# ===========================
# Options: claude, openai, local
AI_PROVIDER=claude

# Claude API (if using Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# OpenAI API (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Local LLM (if using local model)
LOCAL_LLM_ENDPOINT=http://localhost:8000
LOCAL_LLM_MODEL=llama-2-70b

# ===========================
# EHR Configuration
# ===========================
# EHR system type: fujitsu, nec, philips, medicom, generic
EHR_TYPE=fujitsu

# Video capture device index (default: 0 for MiraBox)
CAPTURE_DEVICE_INDEX=0

# Capture resolution
CAPTURE_WIDTH=1920
CAPTURE_HEIGHT=1080

# ===========================
# DocLayout-YOLO Configuration
# ===========================
# Path to DocLayout-YOLO model
DOCLAYOUT_MODEL_PATH=./DocLayout-YOLO/models/doclayout.pt

# Detection confidence threshold
DETECTION_CONFIDENCE=0.2

# Image size for inference
DETECTION_IMAGE_SIZE=1024

# Device: cuda, mps, cpu, or specific GPU like cuda:0
DETECTION_DEVICE=auto

# ===========================
# OCR Configuration
# ===========================
# OCR languages (comma-separated): ja, en, etc.
OCR_LANGUAGES=ja,en

# Use GPU for OCR (true/false)
OCR_USE_GPU=false

# ===========================
# Anonymization Settings
# ===========================
# Age range grouping in years
AGE_RANGE_GROUPING=10

# Enable anonymization audit logging
ANONYMIZATION_AUDIT=true

# ===========================
# Logging
# ===========================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/ehr_bridge.log
AUDIT_LOG_PATH=./audit_logs/audit.log

# ===========================
# Application Settings
# ===========================
# Run in interactive mode by default
INTERACTIVE_MODE=false

# Auto-capture interval in seconds (0 to disable)
AUTO_CAPTURE_INTERVAL=0

# Enable HIPAA compliance mode
HIPAA_COMPLIANCE_MODE=true
